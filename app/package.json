{
  "name": "dreaction",
  "private": true,
  "version": "1.10.0",
  "type": "module",
  "scripts": {
    "start": "electrobun run",
    "dev": "bash scripts/build-css.sh && electrobun dev",
    "dev:watch": "bash scripts/build-css.sh && electrobun dev --watch",
    "build:dev": "bun install && bash scripts/build-css.sh && electrobun build",
    "build:canary": "bash scripts/build-css.sh && electrobun build --env=canary",
    "build:stable": "bash scripts/build-css.sh && electrobun build --env=stable",
    "build:css": "bash scripts/build-css.sh",
    "lint": "eslint . --ext ts,tsx",
    "release": "release-it",
    "release:patch": "release-it -i patch"
  },
  "dependencies": {
    "@mantine/charts": "^7.16.2",
    "@mantine/core": "^7.16.2",
    "@mantine/form": "^7.16.2",
    "@mantine/hooks": "^7.16.2",
    "@mantine/notifications": "^7.16.2",
    "@mantinex/mantine-logo": "^1.0.1",
    "@ngrok/ngrok": "^1.4.1",
    "@tabler/icons-react": "^3.24.0",
    "@tanstack/react-virtual": "^3.13.12",
    "ahooks": "^3.8.4",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dreaction-protocol": "workspace:*",
    "dreaction-server-core": "workspace:*",
    "electrobun": "^1.15.1",
    "lodash-es": "^4.17.21",
    "ms": "^2.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.4.0",
    "react-json-tree": "^0.19.0",
    "react-markdown": "^9.0.3",
    "react-waterfall-timeline": "^1.1.2",
    "recharts": "2",
    "ws": "^8.18.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/ms": "^2.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "release-it": "^18.1.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.2.2"
  }
}
